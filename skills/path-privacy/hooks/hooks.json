{
  "description": "path-privacy hooks: SessionStart injects the rule directive into a git-repo session; PreToolUse Write/Edit blocks would-be leaks before bytes hit disk (the git pre-commit hook remains the authoritative gate).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "timeout": 3,
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.sh"
            ]
          }
        ]
      }
    ]
  }
}
