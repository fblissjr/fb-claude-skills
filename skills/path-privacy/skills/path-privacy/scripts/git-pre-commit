#!/usr/bin/env bash
# path-privacy: skip-file
# git-pre-commit (path-privacy)
# Hard-blocks commits whose staged files contain paths resolving outside the repo root.
# Designed to be invoked from a repo's .git/hooks/pre-commit (chained or standalone).
set -u

# Resolve plugin scripts dir from this file's location.
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
SCANNER="$SELF_DIR/find-external-paths.sh"

# If installed into .git/hooks/, the script may be a copy; allow override via env.
if [ -n "${PATH_PRIVACY_SCRIPT_DIR:-}" ]; then
  SCANNER="$PATH_PRIVACY_SCRIPT_DIR/find-external-paths.sh"
fi

if [ ! -x "$SCANNER" ]; then
  echo "path-privacy: scanner not found or not executable: $SCANNER" >&2
  # Fail CLOSED, matching the installed wrapper. This used to exit 0 "by design",
  # which quietly defeated the wrapper's guarantee one level down: the wrapper
  # carefully selects an executable entry script, that script finds its own
  # delegate missing, and the commit sails through with no gate and no error.
  # A silent bypass on a privacy gate is unrecoverable; a block is loud and fixable.
  echo "  The leak gate is NOT running, so this commit is blocked rather than" >&2
  echo "  allowed through unchecked. Reinstall with /path-privacy:path-privacy." >&2
  exit 1
fi

if ! "$SCANNER" --staged; then
  echo ""
  echo "path-privacy: commit blocked by pre-commit hook." >&2
  echo "Remove the path or replace it with a repo-relative or generic reference, then re-stage." >&2
  exit 1
fi

exit 0
