{
  "description": "skill-maintainer hooks: auto-sync bundled best_practices.md on Edit/Write; nudge session-log-drafter on Stop for substantive sessions",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sync-bundled-ref.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/maybe-draft-session-log.sh"
          }
        ]
      }
    ]
  }
}
